{
  "name": "muse-streaming-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:admin": "npm run dev -w apps/admin",
    "dev:api": "npm run dev -w apps/api",
    "dev:mobile": "npm run dev -w apps/mobile",
    "start:api": "npm run start -w apps/api",
    "start:web": "npm run start -w apps/web",
    "start:admin": "npm run start -w apps/admin",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "smoke": "node scripts/smoke.mjs"
  }
}
